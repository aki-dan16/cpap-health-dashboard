# 正しいDB IDに更新済み
# Notion インテグレーションのアクセストークン（ntn_... / secret_...）
NOTION_TOKEN=

# A. CPAP夜ログ DB ID
NOTION_CPAP_DB_ID=c618f8a18ce24323b8d310c2b5d6d8d4

# B. 血液検査 DB ID
NOTION_BLOOD_DB_ID=854681ce41cb4dfcbee00880778a090b

# C. 体重 DB ID
NOTION_WEIGHT_DB_ID=860cf34325554cac93002ba29d03b862

# D. 投薬ログ DB ID（未設定の場合は投薬ログ関連UIはフェイルセーフで非表示）
NOTION_MEDICATION_DB_ID=

# [auth] Cookieセッション認証（本番で必須・未設定だと本番は503でロック）
# 実値は各自で設定（ローカルは .env.local、Vercelは環境変数）
# BASIC_AUTH_USER は現在の照合では未使用（残置可）。BASIC_AUTH_PASSWORD はログイン照合に流用。
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# [auth] Cookie署名用シークレット（HMAC-SHA256）。未設定だと全ルート503。
# 差し替えると既存セッションが一斉に無効化される（=緊急全ログアウト）。
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#   もしくは: openssl rand -base64 32
AUTH_SECRET=
